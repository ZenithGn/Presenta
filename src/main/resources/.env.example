# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=your_database_aws_rds_endpoint
DB_NAME=Presenta
DB_USER=your_database_username
DB_PASSWORD=your_database_password

# ==========================================
# MOMO CONFIGURATION (SANDBOX)
# ==========================================
MOMO_PARTNER_CODE=your_momo_partner_code_here
MOMO_ACCESS_KEY=your_momo_access_key_here
MOMO_SECRET_KEY=your_momo_secret_key_here
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:8080/EXE202_Maven/MomoReturnController
MOMO_IPN_URL=http://localhost:8080/EXE202_Maven/MomoReturnController

# ==========================================
# VNPAY CONFIGURATION (SANDBOX)
# ==========================================
VNPAY_TMN_CODE=your_vnpay_tmn_code_here
VNPAY_HASH_SECRET=your_vnpay_hash_secret_here
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/EXE202_Maven/VNPayReturnController

# ==========================================
# PAYOS CONFIGURATION
# ==========================================
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here
PAYOS_RETURN_URL=http://localhost:8080/EXE202_Maven/PayOSReturnController
PAYOS_CANCEL_URL=http://localhost:8080/EXE202_Maven/MainController?action=ViewCart

# ==========================================
# EMAIL CONFIGURATION (GMAIL SMTP)
# Email Configuration (Sử dụng Brevo API thay vì SMTP)
# Đăng ký tại https://www.brevo.com/ và lấy API Key trong phần SMTP & API
MAIL_ADDRESS=your-email@gmail.com
BREVO_API_KEY=your_brevo_api_key_here

# Cloudinary Configuration for Image/File Uploads
# Go to https://console.cloudinary.com/ to get your API Environment variable
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>